{
  "name": "ton-rings",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Turn collectible TON rings into evolving digital trophies with verified TON Diamond enchantments.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "build:pages": "npm run generate && node scripts/build-pages.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "verify:public": "node scripts/verify-public.mjs",
    "check": "npm run lint && npm run build && npm test && npm run verify:public",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:prod": "node dist/scripts/migrate.js",
    "generate": "tsx scripts/generate-collection.ts",
    "upload:ipfs": "tsx scripts/upload-pinata.ts",
    "validate:launch": "tsx scripts/validate-launch.ts",
    "prepare:launch": "npm run generate && npm run validate:launch",
    "preflight": "npm run check && npm run validate:launch",
    "mint:readiness": "tsx scripts/check-mint-readiness.ts",
    "mint:prepare:first": "tsx scripts/prepare-first-mint.ts",
    "mint:verify:first": "tsx scripts/verify-first-mint.ts",
    "verify:server": "node -e \"fetch('http://127.0.0.1:'+(process.env.PORT||3000)+'/health').then(r=>{if(!r.ok)throw new Error('health '+r.status);return r.text()}).then(console.log)\""
  },
  "engines": { "node": ">=22" },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@ton/core": "^0.63.1",
    "fastify": "^5.4.0",
    "postgres": "^3.4.7",
    "tweetnacl": "^1.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^10.7.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
